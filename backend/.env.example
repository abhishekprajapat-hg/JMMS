PORT=4000
NODE_ENV=development
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=12h
DEVOTEE_JWT_EXPIRES_IN=30d
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174
# Production example:
# FRONTEND_ORIGINS=https://nemnidhi.tech,https://www.nemnidhi.tech
# Subdomain variant:
# FRONTEND_ORIGINS=https://nemnidhi.tech,https://www.nemnidhi.tech,https://admin.nemnidhi.tech
APP_TIMEZONE=Asia/Kolkata
MONGO_URI=mongodb://127.0.0.1:27017/jmms
DATA_DIR=./data
# Bootstrap staff credentials (applied when a new database is seeded)
BOOTSTRAP_SUPER_ADMIN_USERNAME=superadmin
BOOTSTRAP_SUPER_ADMIN_PASSWORD=
BOOTSTRAP_SUPER_ADMIN_NAME=Platform Super Admin
BOOTSTRAP_TRUSTEE_USERNAME=trustee
BOOTSTRAP_TRUSTEE_PASSWORD=
BOOTSTRAP_TRUSTEE_NAME=Shri Trustee
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Mandir Admin
BOOTSTRAP_EXECUTIVE_USERNAME=executive
BOOTSTRAP_EXECUTIVE_PASSWORD=
BOOTSTRAP_EXECUTIVE_NAME=Sevadar Suman
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v25.0
RECEIPT_PUBLIC_BASE_URL=
# Optional: use pre-approved templates for business-initiated messages on Meta
WHATSAPP_USE_TEMPLATE_FOR_RECEIPTS=false
WHATSAPP_TEMPLATE_INSTANT_RECEIPT=
WHATSAPP_TEMPLATE_PLEDGE_REMINDER=
WHATSAPP_TEMPLATE_LANGUAGE=en_US
# If true, backend will pass the full generated message as {{1}} body variable.
# Use this only when your approved template body includes at least one variable.
WHATSAPP_TEMPLATE_PASS_FULL_MESSAGE_AS_BODY_PARAM=false
# If true, backend sends template first and then follow-up text in the same request flow.
WHATSAPP_TEMPLATE_SEND_FOLLOWUP_TEXT=false
